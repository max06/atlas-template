configs:
  params:
    server.insecure: true
  cm:
    kustomize.buildOptions: --load-restrictor LoadRestrictionsNone --enable-helm

global:
  domain: "argocd.{{  .Values.domain  }}"

server:
  ingress:
    enabled: true

extraObjects:
  - apiVersion: v1
    kind: Secret
    metadata:
      name: argocd-age-secret-keys
      namespace: argocd
    type: Opaque
    stringData:
      keys.txt: |
        {{ .Values | get "ageSecretKey" "No key specified" }}
